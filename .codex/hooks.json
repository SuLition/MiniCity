{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" session-start.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/session-start.sh\"",
            "timeout": 10,
            "statusMessage": "Loading game studio session context"
          },
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" detect-gaps.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/detect-gaps.sh\"",
            "timeout": 10,
            "statusMessage": "Checking game studio documentation gaps"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" validate-commit.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/validate-commit.sh\"",
            "timeout": 15,
            "statusMessage": "Validating commit"
          },
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" validate-push.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/validate-push.sh\"",
            "timeout": 10,
            "statusMessage": "Validating push"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" pre-compact.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pre-compact.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" post-compact.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/post-compact.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" session-stop.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/session-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" log-agent.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/log-agent.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\GameProject\\mini-city\\.codex\\hooks\\invoke-claude-hook.ps1\" log-agent-stop.sh",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/log-agent-stop.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
